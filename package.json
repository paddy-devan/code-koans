{
  "name": "code-koans",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:worker": "wrangler dev",
    "build": "tsc --noEmit --incremental false -p tsconfig.app.json && tsc --noEmit --incremental false -p tsconfig.node.json && tsc --noEmit --incremental false -p tsconfig.worker.json && vite build",
    "preview": "vite preview",
    "worker:typecheck": "tsc --noEmit --incremental false -p tsconfig.worker.json",
    "d1:migrate:local": "wrangler d1 migrations apply code-koans --local",
    "d1:migrate:remote": "wrangler d1 migrations apply code-koans --remote"
  },
  "dependencies": {
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-router-dom": "^7.6.0",
    "vega": "^6.2.0",
    "vega-embed": "^7.1.0"
  },
  "devDependencies": {
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react": "^4.4.1",
    "typescript": "^5.8.3",
    "vite": "^6.3.5",
    "wrangler": "^4.75.0"
  }
}
